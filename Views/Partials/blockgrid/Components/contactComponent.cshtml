@using Umbraco.Cms.Web.Common.PublishedModels;
@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<Umbraco.Cms.Core.Models.Blocks.BlockGridItem<ContactComponent>>
@{
    var content = Model.Content;
    var eyebrow = content.Eyebrow;
    var title = content.Title;
    var subtitle = content.Subtitle;
    var description = content.Description;

    var contactInfos = new List<dynamic>();
    if (!string.IsNullOrWhiteSpace(content.C1Label)) contactInfos.Add(new { icon = content.C1Icon, label = content.C1Label, value = content.C1Value });
    if (!string.IsNullOrWhiteSpace(content.C2Label)) contactInfos.Add(new { icon = content.C2Icon, label = content.C2Label, value = content.C2Value });
    if (!string.IsNullOrWhiteSpace(content.C3Label)) contactInfos.Add(new { icon = content.C3Icon, label = content.C3Label, value = content.C3Value });
}

<div id="contact" data-testid="contact-section" class="w-full">
    <div class="mx-auto max-w-6xl">
        <div class="mb-16 max-w-2xl fade-up">
            <span class="text-xs font-semibold uppercase tracking-[0.25em] text-[#1A2A4F]/50">
                @eyebrow
            </span>
            <h2 class="mt-4 font-[Outfit] text-4xl font-bold leading-[1.05] tracking-tight text-[#1A2A4F] md:text-6xl">
                @Html.Raw(title)
            </h2>
            <p class="mt-6 text-lg leading-relaxed text-[#1A2A4F]/70">
                @subtitle
            </p>
        </div>

        <div class="grid grid-cols-1 gap-12 lg:grid-cols-[1fr_1.5fr] lg:gap-24">
            <div class="fade-up delay-1">
                <div class="space-y-8 rounded-[32px] bg-white p-8 shadow-xl shadow-[#1A2A4F]/5 md:p-10">
                    <p class="mb-8 text-sm leading-relaxed text-[#1A2A4F]/70">
                        @description
                    </p>
                    <div class="space-y-6">
                        @foreach(var info in contactInfos) {
                            <div class="flex items-start gap-4">
                                <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-2xl bg-[#FFF2EF] text-[#1A2A4F]">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                                </div>
                                <div>
                                    <div class="text-xs font-semibold uppercase tracking-wider text-[#1A2A4F]/50">
                                        @info.label
                                    </div>
                                    <div class="mt-1 font-medium text-[#1A2A4F]">
                                        @info.value
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <div class="fade-up delay-2">
                <form class="space-y-6 rounded-[32px] bg-gradient-to-br from-[#1A2A4F] to-[#1A2A4F]/90 p-8 shadow-2xl shadow-[#1A2A4F]/20 md:p-12">
                    <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
                        <div class="space-y-2">
                            <label class="text-sm font-medium text-[#FFF2EF]/80">Név</label>
                            <input type="text" placeholder="Vezetéknév és Keresztnév" class="w-full rounded-2xl border border-white/10 bg-white/5 px-5 py-4 text-[#FFF2EF] placeholder:text-white/30 focus:border-[#F7A5A5] focus:outline-none focus:ring-1 focus:ring-[#F7A5A5] transition-all" />
                        </div>
                        <div class="space-y-2">
                            <label class="text-sm font-medium text-[#FFF2EF]/80">Pozíció / Cég</label>
                            <input type="text" placeholder="CEO, TechGroup" class="w-full rounded-2xl border border-white/10 bg-white/5 px-5 py-4 text-[#FFF2EF] placeholder:text-white/30 focus:border-[#F7A5A5] focus:outline-none focus:ring-1 focus:ring-[#F7A5A5] transition-all" />
                        </div>
                    </div>
                    <div class="space-y-2">
                        <label class="text-sm font-medium text-[#FFF2EF]/80">Email cím</label>
                        <input type="email" placeholder="nev@cegnev.hu" class="w-full rounded-2xl border border-white/10 bg-white/5 px-5 py-4 text-[#FFF2EF] placeholder:text-white/30 focus:border-[#F7A5A5] focus:outline-none focus:ring-1 focus:ring-[#F7A5A5] transition-all" />
                    </div>
                    <div class="space-y-2">
                        <label class="text-sm font-medium text-[#FFF2EF]/80">Hogyan segíthetünk?</label>
                        <textarea rows="4" placeholder="Írd le röviden a jelenlegi helyzetet..." class="w-full resize-none rounded-2xl border border-white/10 bg-white/5 px-5 py-4 text-[#FFF2EF] placeholder:text-white/30 focus:border-[#F7A5A5] focus:outline-none focus:ring-1 focus:ring-[#F7A5A5] transition-all"></textarea>
                    </div>
                    <button type="button" class="mt-4 w-full rounded-full bg-[#F7A5A5] px-8 py-4 text-sm font-bold text-[#1A2A4F] transition-all hover:bg-[#FFDBB6] active:scale-95">
                        Üzenet küldése
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>
