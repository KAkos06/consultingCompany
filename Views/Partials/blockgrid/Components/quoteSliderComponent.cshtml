@using Umbraco.Cms.Web.Common.PublishedModels;
@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<Umbraco.Cms.Core.Models.Blocks.BlockGridItem<QuoteSliderComponent>>
@{
    var content = Model.Content;
    var slides = new List<dynamic>();
    
    if (!string.IsNullOrWhiteSpace(content.Quote1Title)) slides.Add(new { icon = content.Quote1Icon, tag = content.Quote1Tag, title = content.Quote1Title, desc = content.Quote1Desc });
    if (!string.IsNullOrWhiteSpace(content.Quote2Title)) slides.Add(new { icon = content.Quote2Icon, tag = content.Quote2Tag, title = content.Quote2Title, desc = content.Quote2Desc });
    if (!string.IsNullOrWhiteSpace(content.Quote3Title)) slides.Add(new { icon = content.Quote3Icon, tag = content.Quote3Tag, title = content.Quote3Title, desc = content.Quote3Desc });
    if (!string.IsNullOrWhiteSpace(content.Quote4Title)) slides.Add(new { icon = content.Quote4Icon, tag = content.Quote4Tag, title = content.Quote4Title, desc = content.Quote4Desc });
    
    var sliderId = "slider-" + Guid.NewGuid().ToString("N").Substring(0, 8);
}

<div data-testid="quote-slider" class="relative rounded-3xl bg-[#1A2A4F] shadow-2xl shadow-[#1A2A4F]/20 overflow-hidden" id="@sliderId">
    <div class="absolute inset-0 opacity-[0.03] pointer-events-none mix-blend-overlay" style="background-image: url('data:image/svg+xml,%3Csvg viewBox=\'0 0 400 400\' xmlns=\'http://www.w3.org/2000/svg\'%3E%3Cfilter id=\'n\'%3E%3CfeTurbulence type=\'fractalNoise\' baseFrequency=\'0.9\' numOctaves=\'3\'/%3E%3C/filter%3E%3Crect width=\'100%25\' height=\'100%25\' filter=\'url(%23n)\' opacity=\'0.4\'/%3E%3C/svg%3E')"></div>

    <div class="mx-auto flex max-w-6xl items-center gap-6 px-6 py-8">
        <div class="flex-1 overflow-hidden">
            <div class="flex overflow-x-auto snap-x snap-mandatory scrollbar-hide hide-scrollbars" style="scrollbar-width: none; -ms-overflow-style: none;" id="@(sliderId)-container">
                @for (var i = 0; i < slides.Count; i++) {
                    var slide = slides[i];
                    <div data-testid="quote-slide-@i" class="snap-start basis-full shrink-0 grow-0 pr-6 md:basis-1/2 transition-opacity">
                        <div class="flex items-start gap-4">
                            <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl border border-[#F7A5A5]/30 bg-[#F7A5A5]/20 text-[#F7A5A5]">
                                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 21c3 0 7-1 7-8V5c0-1.25-.756-2.017-2-2H4c-1.25 0-2 .75-2 1.972V11c0 1.25.75 2 2 2 1 0 1.5.5 1.5 1.714V15c0 3-4 6-4 6z"/><path d="M15 21c3 0 7-1 7-8V5c0-1.25-.757-2.017-2-2h-4c-1.25 0-2 .75-2 1.972V11c0 1.25.75 2 2 2h.5c0 2.214-.5 2.714-1.5 2.714V15c0 3-4 6-4 6z"/></svg>
                            </div>
                            <div class="min-w-0">
                                <div class="mb-1 text-[10px] font-semibold uppercase tracking-[0.2em] text-[#FFDBB6]">
                                    @slide.tag
                                </div>
                                <div class="line-clamp-2 text-sm font-semibold leading-snug text-[#FFF2EF]">
                                    @slide.title
                                </div>
                                <div class="mt-1 line-clamp-1 text-xs text-[#FFF2EF]/55">
                                    @slide.desc
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>

        <div class="flex shrink-0 items-center gap-2">
            <button onclick="document.getElementById('@(sliderId)-container').scrollBy({left: -300, behavior: 'smooth'})" aria-label="Előző" class="relative z-10 flex h-10 w-10 items-center justify-center rounded-full border border-white/15 text-[#FFF2EF] transition-all hover:bg-white/10 active:scale-95">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
            </button>
            <button onclick="document.getElementById('@(sliderId)-container').scrollBy({left: 300, behavior: 'smooth'})" aria-label="Következő" class="relative z-10 flex h-10 w-10 items-center justify-center rounded-full bg-[#F7A5A5] text-[#1A2A4F] transition-all hover:bg-[#FFDBB6] active:scale-95">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
            </button>
        </div>
    </div>
</div>

<style>
.hide-scrollbars::-webkit-scrollbar {
  display: none;
}
</style>
