@using Umbraco.Cms.Web.Common.PublishedModels;
@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<Umbraco.Cms.Core.Models.Blocks.BlockGridItem<QuoteSliderComponent>>
@{
    var content = Model.Content;
    var slides = new List<dynamic>();
    
    if (content.Quotes != null) {
        foreach (var block in content.Quotes) {
            var iconVal = block.Content.GetIconValue("icon");
            var icon = block.Content.Value<string>("icon") ?? block.Content.Value<IEnumerable<string>>("icon")?.FirstOrDefault() ?? "Quote";
            var tag = block.Content.Value<string>("tag");
            var title = block.Content.Value<string>("title");
            var desc = block.Content.Value<string>("description");
            if (!string.IsNullOrWhiteSpace(title)) {
                slides.Add(new { iconVal = iconVal, icon = icon, tag = tag, title = title, desc = desc });
            }
        }
    }
    
    var sliderId = "slider-" + Guid.NewGuid().ToString("N").Substring(0, 8);
}

<div data-testid="quote-slider" class="relative rounded-3xl bg-[#1A2A4F] shadow-2xl shadow-[#1A2A4F]/20 overflow-hidden" id="@sliderId">
    <div class="absolute inset-0 opacity-[0.03] pointer-events-none mix-blend-overlay" style="background-image: url('data:image/svg+xml,%3Csvg viewBox=\'0 0 400 400\' xmlns=\'http://www.w3.org/2000/svg\'%3E%3Cfilter id=\'n\'%3E%3CfeTurbulence type=\'fractalNoise\' baseFrequency=\'0.9\' numOctaves=\'3\'/%3E%3C/filter%3E%3Crect width=\'100%25\' height=\'100%25\' filter=\'url(%23n)\' opacity=\'0.4\'/%3E%3C/svg%3E')"></div>

    <div class="mx-auto flex max-w-6xl items-center gap-6 px-6 py-8">
        <div class="flex-1 overflow-hidden">
            <div class="flex overflow-x-auto snap-x snap-mandatory scrollbar-hide hide-scrollbars" style="scrollbar-width: none; -ms-overflow-style: none;" id="@(sliderId)-container">
                @for (var i = 0; i < slides.Count; i++) {
                    var slide = slides[i];
                    <div data-testid="quote-slide-@i" class="snap-start basis-full shrink-0 grow-0 pr-6 md:basis-1/2 transition-opacity">
                        <div class="flex items-start gap-4">
                            <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl border border-[#F7A5A5]/30 bg-[#F7A5A5]/20 text-[#F7A5A5]">
                                @if (slide.iconVal != null && !slide.iconVal.IsEmpty) {
                                    @slide.iconVal.Render(size: 20)
                                } else if (slide.icon == "Award") {
                                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="6"/><path d="M15.477 12.89 17 22l-5-3-5 3 1.523-9.11"/></svg>
                                } else if (slide.icon == "TrendingUp") {
                                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/><polyline points="16 7 22 7 22 13"/></svg>
                                } else if (slide.icon == "Users") {
                                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                                } else if (slide.icon == "Star") {
                                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                                } else if (slide.icon == "MessageSquare") {
                                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                                } else if (slide.icon == "Target") {
                                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/></svg>
                                } else if (slide.icon == "Sparkles") {
                                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z"/></svg>
                                } else {
                                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 21c3 0 7-1 7-8V5c0-1.25-.756-2.017-2-2H4c-1.25 0-2 .75-2 1.972V11c0 1.25.75 2 2 2 1 0 1.5.5 1.5 1.714V15c0 3-4 6-4 6z"/><path d="M15 21c3 0 7-1 7-8V5c0-1.25-.757-2.017-2-2h-4c-1.25 0-2 .75-2 1.972V11c0 1.25.75 2 2 2h.5c0 2.214-.5 2.714-1.5 2.714V15c0 3-4 6-4 6z"/></svg>
                                }
                            </div>
                            <div class="min-w-0">
                                <div class="mb-1 text-[10px] font-semibold uppercase tracking-[0.2em] text-[#FFDBB6]">
                                    @slide.tag
                                </div>
                                <div class="line-clamp-2 text-sm font-semibold leading-snug text-[#FFF2EF]">
                                    @slide.title
                                </div>
                                <div class="mt-1 line-clamp-1 text-xs text-[#FFF2EF]/55">
                                    @slide.desc
                                </div>
                            </div>
                        </div>
                    </div>
                }
                <div class="shrink-0 basis-full md:basis-1/2 pointer-events-none opacity-0" aria-hidden="true"></div>
            </div>
        </div>

        <div class="flex shrink-0 items-center gap-4">
            @if (slides.Count > 1) {
                <div class="hidden sm:flex items-center gap-1.5 px-3.5 py-2.5 rounded-2xl bg-[#111E3A] border border-white/10 shadow-inner" id="@(sliderId)-indicators">
                    @for (var i = 0; i < slides.Count; i++) {
                        <div data-index="@i" class="h-1 transition-all duration-300 rounded-full @(i == 0 ? "w-5 bg-[#F7A5A5]" : "w-2 bg-white/30")"></div>
                    }
                </div>
            }
            <div class="flex items-center gap-2">
                <button id="@(sliderId)-prev" aria-label="Előző" class="relative z-10 flex h-10 w-10 items-center justify-center rounded-full border border-white/15 text-[#FFF2EF] transition-all hover:bg-white/10 active:scale-95">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
                </button>
                <button id="@(sliderId)-next" aria-label="Következő" class="relative z-10 flex h-10 w-10 items-center justify-center rounded-full bg-[#F7A5A5] text-[#1A2A4F] transition-all hover:bg-[#FFDBB6] active:scale-95">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
                </button>
            </div>
        </div>
    </div>
</div>

<script>
(() => {
    const init = () => {
        const container = document.getElementById('@(sliderId)-container');
        const indicators = document.querySelectorAll('#@(sliderId)-indicators > div');
        const prevBtn = document.getElementById('@(sliderId)-prev');
        const nextBtn = document.getElementById('@(sliderId)-next');
        if (!container || !indicators.length) return;

        const totalSlides = indicators.length;
        const isAutoplay = @(content.Autoplay.ToString().ToLower());

        const updateUI = (activeIdx) => {
            indicators.forEach((ind, idx) => {
                if (idx === activeIdx) {
                    ind.className = "h-1 transition-all duration-300 rounded-full w-5 bg-[#F7A5A5]";
                } else {
                    ind.className = "h-1 transition-all duration-300 rounded-full w-2 bg-white/30";
                }
            });
        };

        const onScroll = () => {
            const containerLeft = container.getBoundingClientRect().left;
            let closestIdx = 0;
            let minDiff = Infinity;

            Array.from(container.children).forEach((child, idx) => {
                if (idx < totalSlides) {
                    const childLeft = child.getBoundingClientRect().left;
                    const diff = Math.abs(childLeft - containerLeft);
                    if (diff < minDiff) {
                        minDiff = diff;
                        closestIdx = idx;
                    }
                }
            });

            updateUI(closestIdx);
        };

        const getSlideWidth = () => container.children[0]?.clientWidth || 300;

        if (nextBtn) {
            nextBtn.addEventListener('click', () => {
                const maxScroll = container.scrollWidth - container.clientWidth;
                if (container.scrollLeft >= maxScroll - 15) {
                    container.scrollTo({ left: 0, behavior: 'smooth' });
                } else {
                    container.scrollBy({ left: getSlideWidth(), behavior: 'smooth' });
                }
            });
        }

        if (prevBtn) {
            prevBtn.addEventListener('click', () => {
                if (container.scrollLeft <= 15) {
                    container.scrollTo({ left: container.scrollWidth, behavior: 'smooth' });
                } else {
                    container.scrollBy({ left: -getSlideWidth(), behavior: 'smooth' });
                }
            });
        }

        indicators.forEach((ind, idx) => {
            ind.style.cursor = 'pointer';
            ind.addEventListener('click', () => {
                container.scrollTo({ left: idx * getSlideWidth(), behavior: 'smooth' });
            });
        });

        let timer = null;
        const startAutoplay = () => {
            if (!isAutoplay) return;
            stopAutoplay();
            timer = setInterval(() => {
                if (nextBtn) nextBtn.click();
            }, 5000);
        };
        const stopAutoplay = () => {
            if (timer) clearInterval(timer);
        };

        if (isAutoplay) {
            const sliderEl = document.getElementById('@sliderId');
            if (sliderEl) {
                sliderEl.addEventListener('mouseenter', stopAutoplay);
                sliderEl.addEventListener('mouseleave', startAutoplay);
                sliderEl.addEventListener('touchstart', stopAutoplay, { passive: true });
            }
            startAutoplay();
        }

        container.addEventListener('scroll', onScroll, { passive: true });
        onScroll();
    };

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', init);
    } else {
        init();
    }
})();
</script>

<style>
.hide-scrollbars::-webkit-scrollbar {
  display: none;
}
</style>
