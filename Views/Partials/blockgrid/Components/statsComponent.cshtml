@using Umbraco.Cms.Web.Common.PublishedModels;
@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<Umbraco.Cms.Core.Models.Blocks.BlockGridItem<StatsComponent>>
@{
    var content = Model.Content;
    var statBlocks = content.Stats;
}

<div data-testid="stats-section" class="w-full py-12">
    @if (statBlocks != null && statBlocks.Any()) {
        var total = statBlocks.Count();
        var gridCols = total switch {
            1 => "grid-cols-1 max-w-sm",
            2 => "grid-cols-2 max-w-2xl",
            3 => "grid-cols-2 md:grid-cols-3 max-w-4xl",
            _ => "grid-cols-2 md:grid-cols-4 max-w-6xl"
        };

        <div class="mx-auto max-w-6xl border-y border-[#1A2A4F]/10 py-12 px-4">
            <div class="mx-auto grid @gridCols gap-8 divide-x divide-[#1A2A4F]/10 w-full">
                @{ var i = 0; }
                @foreach (var block in statBlocks) {
                    var stat = (StatItem)block.Content;
                    var isOddLast = (i == total - 1) && (total % 2 != 0) && total > 1;
                    var spanClass = isOddLast ? "col-span-2 md:col-span-1" : "";
                    
                    <div data-testid="stat-@i" class="flex flex-col items-center justify-center text-center fade-up delay-@i @spanClass">
                        <div class="mb-2 font-[Outfit] text-4xl font-bold tracking-tight text-[#1A2A4F] md:text-5xl">
                            @stat.Number
                        </div>
                        <div class="text-sm font-semibold uppercase tracking-[0.15em] text-[#1A2A4F]/50">
                            @stat.Label
                        </div>
                    </div>
                    i++;
                }
            </div>
        </div>
    }
</div>
