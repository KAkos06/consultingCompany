@using Umbraco.Cms.Web.Common.PublishedModels;
@using Umbraco.Extensions;
@using Umbraco.Cms.Core.Models;
@using Umbraco.Cms.Core.Models.Blocks;
@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage
@{
    var siteRoot = Model.Root();
    var settings = Umbraco.ContentAtRoot().FirstOrDefault(x => x.ContentType.Alias == "siteSettings" || x.ContentType.Alias == "settings") 
        ?? siteRoot?.Children.FirstOrDefault(x => x.ContentType.Alias == "siteSettings" || x.ContentType.Alias == "settings")
        ?? siteRoot?.SiblingsAndSelf().FirstOrDefault(x => x.ContentType.Alias == "siteSettings" || x.ContentType.Alias == "settings");
    
    var brandName = settings?.Value<string>("logoText") ?? "Executive Insights";
    var navBlocks = settings?.Value<BlockListModel>("headerNavLinks");
    var ctaBlocks = settings?.Value<BlockListModel>("headerCtaButton");
    
    // Legacy fallback
    var legacyCtaLabel = settings?.Value<string>("headerCtaLabel") ?? "Kapcsolat";
    var legacyCtaLink = settings?.Value<string>("headerCtaLink") ?? "/kapcsolat";
}

<style>
  .nav-item-dropdown { position: relative; padding: 8px 0; }
  .mega-menu-panel {
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%) translateY(10px);
    width: 480px;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: opacity 0.2s ease, transform 0.2s ease, visibility 0.2s;
    z-index: 1000;
    padding-top: 8px;
  }
  .nav-item-dropdown:hover .mega-menu-panel {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
    transform: translateX(-50%) translateY(0);
  }
  .mega-menu-card {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    padding: 12px;
    border-radius: 16px;
    transition: background-color 0.15s ease;
    text-decoration: none;
  }
  .mega-menu-card:hover {
    background-color: #FFF2EF;
  }
  .mega-menu-icon {
    width: 44px;
    height: 44px;
    flex-shrink: 0;
    border-radius: 12px;
    background-color: rgba(255, 219, 182, 0.4);
    display: flex;
    align-items: center;
    justify-content: center;
    color: #1A2A4F;
    transition: background-color 0.15s ease;
  }
  .mega-menu-card:hover .mega-menu-icon {
    background-color: rgba(247, 165, 165, 0.5);
  }
</style>

<!-- Modern Dynamic Scrolling Nav with MegaMenu Tree Support -->
<header id="main-navbar" class="nav-shell nav-floating fixed top-0 left-1/2 -translate-x-1/2 z-50 bg-white/95 backdrop-blur-md shadow-[0_8px_32px_rgba(26,42,79,0.18)] py-3 border border-[#1A2A4F]/5">
  <div class="nav-shell-inner flex items-center justify-between">
    <a href="/" class="flex items-center gap-3 shrink-0 group" style="text-decoration: none;">
      <div class="w-10 h-10 rounded-full bg-[#1A2A4F] text-[#FFDBB6] flex items-center justify-center font-bold text-xl font-[Outfit] group-hover:scale-105 transition-transform">
        EI
      </div>
      <span class="font-[Outfit] font-bold text-[#1A2A4F] text-lg tracking-tight">
        @brandName
      </span>
    </a>

    <nav class="hidden md:flex items-center gap-8 text-sm font-semibold text-[#1A2A4F]">
      @if(navBlocks != null && navBlocks.Any()) {
        foreach(var block in navBlocks) {
          var alias = block.Content.ContentType.Alias;
          if (alias.Equals("linkItem", StringComparison.OrdinalIgnoreCase)) {
            var links = block.Content.Value<IEnumerable<Link>>("link");
            var link = links?.FirstOrDefault();
            if (link != null) {
              <a href="@link.Url" target="@link.Target" class="nav-link hover:text-[#F7A5A5] transition-colors" style="text-decoration: none;">@link.Name</a>
            }
          } else if (alias.Equals("megaMenuItem", StringComparison.OrdinalIgnoreCase)) {
            var links = block.Content.Value<IEnumerable<Link>>("link");
            var topLink = links?.FirstOrDefault();
            var tabName = topLink?.Name ?? "Menü";
            var tabUrl = topLink?.Url ?? "#";
            var subBlocks = block.Content.Value<BlockListModel>("subItems");
            
            <div class="nav-item-dropdown cursor-pointer">
              <a href="@tabUrl" class="nav-link inline-flex items-center gap-1 hover:text-[#F7A5A5] transition-colors" style="text-decoration: none; display: inline-flex; align-items: center; gap: 4px;">
                @tabName
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="transition: transform 0.2s;"><path d="m6 9 6 6 6-6"/></svg>
              </a>
              @if (subBlocks != null && subBlocks.Any()) {
                <div class="mega-menu-panel">
                  <div class="bg-white rounded-[28px] shadow-[0_24px_64px_-12px_rgba(26,42,79,0.25)] p-5 grid grid-cols-2 gap-2 border border-[#1A2A4F]/10" style="background: white; border-radius: 28px; box-shadow: 0 24px 64px -12px rgba(26,42,79,0.25); padding: 20px; display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 8px; border: 1px solid rgba(26,42,79,0.08);">
                    @foreach(var sub in subBlocks) {
                      var subLinks = sub.Content.Value<IEnumerable<Link>>("link");
                      var subLink = subLinks?.FirstOrDefault();
                      if (subLink != null) {
                        var subName = subLink.Name;
                        var subUrl = subLink.Url;
                        var subTarget = subLink.Target;
                        var subDesc = sub.Content.Value<string>("description");
                        var subIcon = sub.Content.Value<string>("icon");
                        var subIconVal = sub.Content.GetIconValue("icon");
                        
                        <a href="@subUrl" target="@subTarget" class="mega-menu-card">
                          <div class="mega-menu-icon">
                            @if (subIconVal != null && !subIconVal.IsEmpty) {
                              @subIconVal.Render(size: 20)
                            } else {
                              @RenderSvgIcon(subIcon, 20)
                            }
                          </div>
                          <div style="min-width: 0;">
                            <div style="font-weight: 600; color: #1A2A4F; font-size: 14px; line-height: 1.25;">@subName</div>
                            @if(!string.IsNullOrWhiteSpace(subDesc)) {
                              <div style="font-size: 12px; color: rgba(26,42,79,0.6); margin-top: 4px; line-height: 1.35;">@subDesc</div>
                            }
                          </div>
                        </a>
                      }
                    }
                  </div>
                </div>
              }
            </div>
          }
        }
      } else {
        @* Legacy navigation links fallback *@
        var legacyNav = settings?.Value<IEnumerable<Link>>("headerNavLinks");
        if (legacyNav != null) {
          foreach(var link in legacyNav) {
            <a href="@link.Url" target="@link.Target" class="nav-link hover:text-[#F7A5A5] transition-colors" style="text-decoration: none;">@link.Name</a>
          }
        }
      }
    </nav>

    <div class="flex items-center gap-3">
      @if (ctaBlocks != null && ctaBlocks.Any()) {
        var ctaBlock = ctaBlocks.FirstOrDefault()?.Content;
        var ctaLinks = ctaBlock?.Value<IEnumerable<Link>>("link");
        var ctaLinkObj = ctaLinks?.FirstOrDefault();
        if (ctaLinkObj != null) {
          var ctaIcon = ctaBlock?.Value<string>("icon");
          var ctaIconVal = ctaBlock?.GetIconValue("icon");
          <a href="@ctaLinkObj.Url" target="@ctaLinkObj.Target" class="inline-flex items-center gap-2 bg-[#F7A5A5] text-[#1A2A4F] px-6 py-2.5 rounded-full text-sm font-bold shadow-md hover:bg-[#FFDBB6] active:scale-95 transition-all" style="text-decoration: none; display: inline-flex; align-items: center; gap: 8px; background: #F7A5A5; color: #1A2A4F; padding: 10px 24px; border-radius: 9999px; font-size: 14px; font-weight: 700; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1);">
            @if(ctaIconVal != null && !ctaIconVal.IsEmpty) {
              @ctaIconVal.Render(size: 18)
            } else if(!string.IsNullOrWhiteSpace(ctaIcon)) {
              @RenderSvgIcon(ctaIcon, 18)
            }
            @ctaLinkObj.Name
          </a>
        }
      } else {
        @* Legacy CTA fallback *@
        <a href="@legacyCtaLink" class="inline-flex items-center gap-2 bg-[#F7A5A5] text-[#1A2A4F] px-6 py-2.5 rounded-full text-sm font-bold shadow-md hover:bg-[#FFDBB6] active:scale-95 transition-all" style="text-decoration: none; display: inline-flex; align-items: center; gap: 8px; background: #F7A5A5; color: #1A2A4F; padding: 10px 24px; border-radius: 9999px; font-size: 14px; font-weight: 700;">
          @legacyCtaLabel
        </a>
      }
    </div>
  </div>
</header>

@functions {
    public static Microsoft.AspNetCore.Html.HtmlString RenderSvgIcon(string name, int size = 18)
    {
        var paths = name switch {
            "Compass" => "<circle cx=\"12\" cy=\"12\" r=\"10\"/><polygon points=\"16.24 7.76 14.12 14.12 7.76 16.24 9.88 9.88 16.24 7.76\"/>",
            "Users" => "<path d=\"M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2\"/><circle cx=\"9\" cy=\"7\" r=\"4\"/><path d=\"M22 21v-2a4 4 0 0 0-3-3.87\"/><path d=\"M16 3.13a4 4 0 0 1 0 7.75\"/>",
            "TrendingUp" => "<polyline points=\"22 7 13.5 15.5 8.5 10.5 2 17\"/><polyline points=\"16 7 22 7 22 13\"/>",
            "Lightbulb" => "<path d=\"M15 14c.2-1 .7-1.7 1.5-2.5 1-.9 1.5-2.2 1.5-3.5A6 6 0 0 0 6 8c0 1 .2 2.2 1.5 3.5.7.7 1.3 1.5 1.5 2.5\"/><path d=\"M9 18h6\"/><path d=\"M10 22h4\"/>",
            "BookOpen" => "<path d=\"M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z\"/><path d=\"M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z\"/>",
            "Sparkles" => "<path d=\"m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z\"/>",
            "Mail" => "<rect width=\"20\" height=\"16\" x=\"2\" y=\"4\" rx=\"2\"/><path d=\"m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7\"/>",
            "Phone" => "<path d=\"M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z\"/>",
            "MessageSquare" => "<path d=\"M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z\"/>",
            "ArrowRight" => "<path d=\"M5 12h14\"/><path d=\"m12 5 7 7-7 7\"/>",
            "ExternalLink" => "<path d=\"M15 3h6v6\"/><path d=\"M10 14 21 3\"/><path d=\"M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6\"/>",
            "Award" => "<circle cx=\"12\" cy=\"8\" r=\"6\"/><path d=\"M15.477 12.89 17 22l-5-3-5 3 1.523-9.11\"/>",
            "Target" => "<circle cx=\"12\" cy=\"12\" r=\"10\"/><circle cx=\"12\" cy=\"12\" r=\"6\"/><circle cx=\"12\" cy=\"12\" r=\"2\"/>",
            "Star" => "<polygon points=\"12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2\"/>",
            _ => "<path d=\"M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71\"/><path d=\"M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71\"/>"
        };
        var svg = $"<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"{size}\" height=\"{size}\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\">{paths}</svg>";
        return new Microsoft.AspNetCore.Html.HtmlString(svg);
    }
}
