    {
      "contentTypeKey": "b2222222-2222-2222-2222-222222222222",
      "key": "20000000-0000-0000-0000-000000000004",
      "values": [
        {
          "alias": "tag",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "02 - R\u00F3lunk"
        },
        {
          "alias": "title",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "12 \u00E9v, 240\u002B vezet\u0151, egyetlen k\u00FCldet\u00E9s."
        },
        {
          "alias": "subtitle",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Az Executive Insights 2013-ban indult azzal a meggy\u0151z\u0151d\u00E9ssel, hogy a legjobb vezet\u0151k sem dolgoznak egyed\u00FCl. A magyar \u00E9s k\u00F6z\u00E9p-eur\u00F3pai piac fels\u0151 vezet\u0151ivel dolgozunk egy\u00FCtt diszkr\u00E9ten, m\u00E9lyen \u00E9s m\u00E9rhet\u0151 eredm\u00E9nnyel."
        },
        {
          "alias": "stat1Label",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Vezet\u0151i NPS 2024"
        },
        {
          "alias": "stat1Value",
          "culture": null,
