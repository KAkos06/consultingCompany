                "values": [
                  {
                    "alias": "text",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Diszkr\u00E9ci\u00F3 \u00E9s felt\u00E9tlen bizalom"
                  }
                ]
              },
              {
                "contentTypeKey": "b7777777-7777-7777-7777-777777777771",
                "key": "20e8a8ed-8261-4303-8125-6cd52c60afa3",
                "values": [
                  {
                    "alias": "text",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Saj\u00E1t c\u00E9gvezet\u0151i tapasztalat minden mentorunkn\u00E1l"
                  }
                ]
              },
              {
                "contentTypeKey": "b7777777-7777-7777-7777-777777777771",
                "key": "27c40b10-f5f4-4acd-ab33-6a7f3db98603",
                "values": [
                  {
                    "alias": "text",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Gyakorlatias, azonnal alkalmazhat\u00F3 strat\u00E9gi\u00E1k"
                  }
                ]
              },
              {
                "contentTypeKey": "b7777777-7777-7777-7777-777777777771",
                "key": "8f14bf75-f14c-4787-9720-ca128b2e6282",
                "values": [
                  {
                    "alias": "text",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Kiterjedt, exkluz\u00EDv kapcsolatrendszer"
                  },
