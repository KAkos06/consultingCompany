    {
      "contentTypeKey": "b2222222-2222-2222-2222-222222222222",
      "key": "20000000-0000-0000-0000-000000000004",
      "values": [
        {
          "alias": "tag",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "02 - R\u00F3lunk"
        },
        {
          "alias": "title",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "12 \u00E9v, 240\u002B vezet\u0151, egyetlen k\u00FCldet\u00E9s."
        },
        {
          "alias": "subtitle",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Az Executive Insights 2013-ban indult azzal a meggy\u0151z\u0151d\u00E9ssel, hogy a legjobb vezet\u0151k sem dolgoznak egyed\u00FCl. A magyar \u00E9s k\u00F6z\u00E9p-eur\u00F3pai piac fels\u0151 vezet\u0151ivel dolgozunk egy\u00FCtt diszkr\u00E9ten, m\u00E9lyen \u00E9s m\u00E9rhet\u0151 eredm\u00E9nnyel."
        },
        {
          "alias": "stat1Label",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Vezet\u0151i NPS 2024"
        },
        {
          "alias": "stat1Value",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "\u002B78"
        },
        {
          "alias": "bullets",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": {
            "contentData": [
              {
                "contentTypeKey": "b7777777-7777-7777-7777-777777777771",
                "key": "4769a278-ad33-431d-98f3-6c09355a6505",
                "values": [
                  {
                    "alias": "text",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Diszkr\u00E9ci\u00F3 \u00E9s felt\u00E9tlen bizalom"
                  }
                ]
              },
              {
                "contentTypeKey": "b7777777-7777-7777-7777-777777777771",
                "key": "20e8a8ed-8261-4303-8125-6cd52c60afa3",
                "values": [
                  {
                    "alias": "text",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Saj\u00E1t c\u00E9gvezet\u0151i tapasztalat minden mentorunkn\u00E1l"
                  }
                ]
              },
              {
                "contentTypeKey": "b7777777-7777-7777-7777-777777777771",
                "key": "27c40b10-f5f4-4acd-ab33-6a7f3db98603",
                "values": [
                  {
                    "alias": "text",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Gyakorlatias, azonnal alkalmazhat\u00F3 strat\u00E9gi\u00E1k"
                  }
                ]
              },
              {
                "contentTypeKey": "b7777777-7777-7777-7777-777777777771",
                "key": "8f14bf75-f14c-4787-9720-ca128b2e6282",
                "values": [
                  {
                    "alias": "text",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Kiterjedt, exkluz\u00EDv kapcsolatrendszer"
                  },
                  {
                    "alias": "icon",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": {
                      "icon": "mdi:alien-outline",
                      "color": "#000000"
