    {
      "contentTypeKey": "b3333333-3333-3333-3333-333333333333",
      "key": "20000000-0000-0000-0000-000000000003",
      "values": [
        {
          "alias": "eyebrow",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Szolg\u00E1ltat\u00E1saink"
        },
        {
          "alias": "title",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Amiben a \u003Cspan class=\u0022italic text-[#F7A5A5]\u0022\u003Elegjobbak\u003C/span\u003E vagyunk."
        },
        {
          "alias": "subtitle",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Nem k\u00EDn\u00E1lunk tucatmegold\u00E1sokat. Kiz\u00E1r\u00F3lag olyan ter\u00FCleteken v\u00E1llalunk partners\u00E9get, ahol a mentoraink t\u00F6bb \u00E9vtizedes szem\u00E9lyes tapasztalata azonnali \u00E9s m\u00E9rhet\u0151 \u00E9rt\u00E9ket teremt."
        },
        {
          "alias": "variant",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": [
            "cream"
          ]
        },
        {
          "alias": "services",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": {
            "contentData": [
              {
                "contentTypeKey": "c5555555-5555-5555-5555-555555555551",
                "key": "c8d8cc1c-f277-4363-813e-7cefa73bbf59",
                "values": [
                  {
                    "alias": "title",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Executive Coaching"
                  },
                  {
                    "alias": "description",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Egy\u00E9ni f\u00F3kusz\u00FA, intenz\u00EDv fejleszt\u00E9s C-szint\u0171 vezet\u0151knek, hogy a legnehezebb helyzetekben is magabiztosan d\u00F6ntsenek."
                  },
                  {
                    "alias": "icon",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": {
                      "icon": "mdi:antenna",
                      "color": "#000000"
                    }
                  },
                  {
                    "alias": "tag",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Coaching"
                  }
                ]
              },
              {
                "contentTypeKey": "c5555555-5555-5555-5555-555555555551",
                "key": "96c06709-23f5-4ef5-b8c6-a862611365cc",
                "values": [
                  {
                    "alias": "title",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Vezet\u0151s\u00E9gi Mentor\u00E1l\u00E1s"
                  },
                  {
                    "alias": "description",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "A menedzsment csapatok \u00F6sszehangol\u00E1sa, a k\u00F6z\u00F6s strat\u00E9giai v\u00EDzi\u00F3 kialak\u00EDt\u00E1sa \u00E9s a bels\u0151 fesz\u00FClts\u00E9gek felold\u00E1sa."
                  },
                  {
                    "alias": "icon",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": {
                      "icon": "mdi:archive-arrow-down",
                      "color": "#000000"
                    }
                  }
                ]
              },
              {
                "contentTypeKey": "c5555555-5555-5555-5555-555555555551",
                "key": "070dde07-ff79-47cd-9bcc-e37737a2036b",
                "values": [
                  {
                    "alias": "title",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Strat\u00E9giai Tan\u00E1csad\u00E1s"
                  },
                  {
                    "alias": "description",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Ir\u00E1nyv\u00E1lt\u00E1sok, akviz\u00EDci\u00F3k vagy kr\u00EDzishelyzetek objekt\u00EDv, k\u00FCls\u0151 szak\u00E9rt\u0151i t\u00E1mogat\u00E1sa \u00E9s levez\u00E9nyl\u00E9se."
                  },
