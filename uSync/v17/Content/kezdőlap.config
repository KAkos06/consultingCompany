    {
      "contentTypeKey": "b7777777-7777-7777-7777-777777777777",
      "key": "20000000-0000-0000-0000-000000000006",
      "values": [
        {
          "alias": "eyebrow",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Visszajelz\u00E9sek"
        },
        {
          "alias": "title",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Amit a \u003Cspan class=\u0022italic text-[#F7A5A5]\u0022\u003Epartnereink\u003C/span\u003E mondanak."
        },
        {
          "alias": "subtitle",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "\u00DCgyfeleink nev\u00E9t \u00E9s c\u00E9g\u00E9t diszkr\u00E9ci\u00F3s okokb\u00F3l nem mindig v\u00E1llalhatjuk publikusan, de az eredm\u00E9nyeik maguk\u00E9rt besz\u00E9lnek."
        },
        {
          "alias": "testimonials",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": {
            "contentData": [
              {
                "contentTypeKey": "b7777777-7777-7777-7777-777777777701",
                "key": "7cfeff19-95f2-43ae-98d3-d0bba99ae68d",
                "values": [
                  {
                    "alias": "quote",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Az Executive Insights csapata nem csak elm\u00E9leti tan\u00E1csokat adott, hanem olyan gyakorlati megk\u00F6zel\u00EDt\u00E9st, amit azonnal be tudtam \u00E9p\u00EDteni a heti vezet\u0151i \u00E9rtekezletekbe. A csapatom dinamik\u00E1ja egy h\u00F3nap alatt \u00E9rezhet\u0151en javult."
                  },
                  {
                    "alias": "name",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Kov\u00E1cs G\u00E1bor"
                  },
                  {
                    "alias": "role",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Vez\u00E9rigazgat\u00F3, TechLogistics Kft."
                  }
                ]
              },
              {
                "contentTypeKey": "b7777777-7777-7777-7777-777777777701",
                "key": "36f61c44-f0b0-4353-87c0-4a7e37ec06bd",
                "values": [
                  {
                    "alias": "quote",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Az Executive Insights csapata nem csak elm\u00E9leti tan\u00E1csokat adott, hanem olyan gyakorlati megk\u00F6zel\u00EDt\u00E9st, amit azonnal be tudtam \u00E9p\u00EDteni a heti vezet\u0151i \u00E9rtekezletekbe. A csapatom dinamik\u00E1ja egy h\u00F3nap alatt \u00E9rezhet\u0151en javult."
                  },
                  {
                    "alias": "name",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Kov\u00E1cs G\u00E1bor"
                  },
